\section{まとめ}

\begin{frame}{まとめ}
  \begin{itemize}
    \item 特異モデルでは古典的漸近論が破綻
    \item 実対数閾値 $\lambda$ が汎化誤差の主要項を決める
  \end{itemize}
\end{frame}

